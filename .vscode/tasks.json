{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend",
            "command": "dotnet",
            "type": "process",
            "args": ["run", "--project", "${workspaceFolder}/MaiChartManager"],
            "isBackground": true,
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            },
            "runOptions": { "reevaluateOnRerun": true },
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "icon": { "id": "server-process" }
        },
        {
            "label": "Dev Server",
            "type": "shell",
            "command": "pnpm dev",
            "options": { "cwd": "${workspaceFolder}/MaiChartManager/Front" },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "icon": { "id": "play" }
        },
        {
            "label": "Gen Client",
            "type": "shell",
            "command": "pnpm genClient",
            "options": { "cwd": "${workspaceFolder}/MaiChartManager/Front" },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" },
            "icon": { "id": "refresh" }
        }
    ]
}
